{
    "crons": [
        {
            "path": "/api/cron/generate-daily-practice",
            "schedule": "30 7 * * 1-6"
        },
        {
            "path": "/api/cron/generate-weekly-tests",
            "schedule": "30 9 * * 0"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, must-revalidate"
                }
            ]
        }
    ]
}